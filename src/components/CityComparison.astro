---
import data from '../data/fatalities.json';

const permitTimeline = data.permitTimeline;
const maxMonths = Math.max(...permitTimeline.map(c => c.months));
const causes = data.dcFatalities.causeBreakdown;
---

<section class="section">
  <div class="container">
    <div class="data-grid">
      <div class="data-panel">
        <h3>Time to Permit: Testing → Commercial Launch</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">
          Months from first Waymo testing to commercial ride-hail service
        </p>
        <div class="permit-chart">
          {permitTimeline.map(city => (
            <div class="bar-row">
              <div class="bar-city">{city.city}</div>
              <div class="bar-track">
                <div
                  class={`bar-fill ${city.status}`}
                  style={`width: ${(city.months / maxMonths) * 100}%`}
                />
              </div>
              <div class="bar-count">
                {city.status === 'waiting' ? `${city.months}+` : city.months} mo
              </div>
            </div>
          ))}
        </div>
        <p style="font-size: 0.75rem; color: var(--text-dim); margin-top: 14px;">
          DC has been testing since April 2024 with no commercial permit in sight.
        </p>
      </div>

      <div class="data-panel">
        <h3>DC Fatalities by Cause</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">
          Factors that autonomous vehicles eliminate
        </p>
        <div class="cause-grid">
          <div class="cause-item">
            <div class="cause-pct">{(causes.drunkDriving * 100).toFixed(0)}%</div>
            <div class="cause-name">Drunk driving</div>
            <div class="cause-note">AVs don't drink</div>
          </div>
          <div class="cause-item">
            <div class="cause-pct">{(causes.speeding * 100).toFixed(0)}%</div>
            <div class="cause-name">Speeding</div>
            <div class="cause-note">AVs obey speed limits</div>
          </div>
          <div class="cause-item">
            <div class="cause-pct">{(causes.distraction * 100).toFixed(0)}%</div>
            <div class="cause-name">Distraction</div>
            <div class="cause-note">AVs don't text</div>
          </div>
          <div class="cause-item">
            <div class="cause-pct">{((causes.drunkDriving + causes.speeding + causes.distraction) * 100).toFixed(0)}%</div>
            <div class="cause-name">Total AV-preventable</div>
            <div class="cause-note">Combined human-error factors</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
