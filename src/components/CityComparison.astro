---
import data from '../data/fatalities.json';

const permits = data.permitTimeline;
const causes = data.seattleFatalities.causeBreakdown;

// Time axis: Jan 2023 to Apr 2026 = 39 months
const axisStart = new Date(2023, 0, 1).getTime();
const axisEnd = new Date(2026, 3, 1).getTime();
const axisSpan = axisEnd - axisStart;

function monthToTime(ym: string) {
  const [y, m] = ym.split('-').map(Number);
  return new Date(y, m - 1, 1).getTime();
}

const cityBars = permits.map(city => {
  const start = monthToTime(city.testStart);
  const end = city.commercialLaunch ? monthToTime(city.commercialLaunch) : axisEnd;
  return {
    city: city.city.replace(/, \w+$/, ''),
    left: ((start - axisStart) / axisSpan) * 100,
    width: ((end - start) / axisSpan) * 100,
    status: city.status,
    months: city.months,
  };
});

const axisYears = [2023, 2024, 2025, 2026];
const yearMarks = axisYears.map(y => ({
  year: y,
  left: ((new Date(y, 0, 1).getTime() - axisStart) / axisSpan) * 100,
}));
---

<section class="section">
  <div class="container">
    <div class="data-grid">
      <div class="data-panel">
        <h3>Meanwhile, Elsewhere</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 20px;">
          Months from first Waymo testing to commercial ride-hail service
        </p>
        <div class="gantt-chart">
          <div class="gantt-axis">
            {yearMarks.map(ym => (
              <div class="gantt-year" style={`left: ${ym.left}%`}>{ym.year}</div>
            ))}
          </div>
          {cityBars.map(bar => (
            <div class="gantt-row">
              <div class="gantt-city">{bar.city}</div>
              <div class="gantt-track">
                <div
                  class={`gantt-bar ${bar.status}`}
                  style={`left: ${bar.left}%; width: ${bar.width}%`}
                />
              </div>
              <div class="gantt-label">
                {bar.status === 'waiting' ? `${bar.months}+ mo` : `${bar.months} mo`}
              </div>
            </div>
          ))}
          <div class="gantt-legend">
            <span class="gantt-legend-item"><span class="gantt-dot approved" /> Testing → launched</span>
            <span class="gantt-legend-item"><span class="gantt-dot waiting" /> Testing → no legal pathway</span>
          </div>
        </div>
      </div>

      <div class="data-panel">
        <h3>WA Fatalities by Cause</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 16px;">
          Factors that autonomous vehicles eliminate
          (<a href={causes.sourceUrl} target="_blank" rel="noopener" style="font-size: 0.75rem;">WTSC 2023</a>)
        </p>
        <div class="cause-grid">
          <div class="cause-item">
            <div class="cause-pct">{(causes.impaired * 100).toFixed(0)}%</div>
            <div class="cause-name">Impaired driving</div>
            <div class="cause-note">AVs don't drink</div>
          </div>
          <div class="cause-item">
            <div class="cause-pct">{(causes.speeding * 100).toFixed(0)}%</div>
            <div class="cause-name">Speeding</div>
            <div class="cause-note">AVs obey speed limits</div>
          </div>
          <div class="cause-item">
            <div class="cause-pct">{(causes.distraction * 100).toFixed(0)}%</div>
            <div class="cause-name">Distraction</div>
            <div class="cause-note">AVs don't text</div>
          </div>
        </div>
        <p style="font-size: 0.7rem; color: var(--text-dim); margin-top: 12px;">
          {causes.note}
        </p>
      </div>
    </div>
  </div>
</section>
