---
import data from '../data/fatalities.json';

const events = data.timeline;
const permits = data.permitTimeline;

// Parse timeline date strings to timestamps
function parseTimelineDate(d: string): number {
  if (/^\d{4}$/.test(d)) return new Date(parseInt(d), 0, 1).getTime();
  const monthMap: Record<string, number> = {
    Jan: 0, Feb: 1, Mar: 2, April: 3, Apr: 3, May: 4, Jun: 5,
    July: 6, Jul: 6, Aug: 7, Sep: 8, Oct: 9, Nov: 10, Dec: 11, Late: 9,
  };
  const parts = d.split(' ');
  const month = monthMap[parts[0]] ?? 0;
  const year = parseInt(parts[parts.length - 1]);
  return new Date(year, month, 1).getTime();
}

function monthToTime(ym: string): number {
  const [y, m] = ym.split('-').map(Number);
  return new Date(y, m - 1, 1).getTime();
}

const nodeTimes = events.map(e => parseTimelineDate(e.date));

// Build city milestones (skip DC)
type Milestone = { city: string; event: string; type: 'testing' | 'launch'; time: number };
const cityMilestones: Milestone[] = [];
for (const city of permits) {
  if (city.status === 'waiting') continue;
  const short = city.city.replace(/, \w+$/, '');
  cityMilestones.push({ city: short, event: `${short} begins testing`, type: 'testing', time: monthToTime(city.testStart) });
  if (city.commercialLaunch) {
    cityMilestones.push({ city: short, event: `${short} launches`, type: 'launch', time: monthToTime(city.commercialLaunch) });
  }
}
cityMilestones.sort((a, b) => a.time - b.time);

// Assign each milestone to the last timeline node before it
const nodeAnnotations: Milestone[][] = events.map(() => []);
for (const ms of cityMilestones) {
  let assignTo = 0;
  for (let i = 0; i < nodeTimes.length; i++) {
    if (nodeTimes[i] <= ms.time) assignTo = i;
    else break;
  }
  nodeAnnotations[assignTo].push(ms);
}
---

<section class="section">
  <div class="container">
    <h2 class="section-title">The Delay</h2>
    <p class="section-subtitle">A timeline of DC's autonomous vehicle regulatory failure</p>

    <div class="timeline">
      {events.map((event, i) => (
        <div class={`timeline-node ${i === events.length - 1 ? 'active' : ''}`}>
          <div class="timeline-dot" />
          <div class="timeline-node-content">
            <div class="timeline-date">{event.date}</div>
            <div class="timeline-event">{event.event}</div>
            <div class="timeline-detail">{event.detail}</div>
            {event.cumulativeDeaths !== null && event.cumulativeDeaths > 0 && (
              <div class="timeline-deaths">
                {event.cumulativeDeaths} road deaths since delay began
              </div>
            )}
          </div>
          {nodeAnnotations[i].length > 0 && (
            <div class="timeline-milestones">
              {nodeAnnotations[i].map(ms => (
                <div class={`milestone ${ms.type}`}>
                  {ms.event}{ms.type === 'launch' ? ' \u2713' : ''}
                </div>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
