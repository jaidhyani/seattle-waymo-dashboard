---
import data from '../data/fatalities.json';

const events = data.timeline;
const permits = data.permitTimeline;

// Time axis: Jan 2023 to Mar 2026 = 38 months
const axisStart = new Date(2023, 0, 1).getTime();
const axisEnd = new Date(2026, 2, 1).getTime();
const axisSpan = axisEnd - axisStart;

function monthToTime(ym: string) {
  const [y, m] = ym.split('-').map(Number);
  return new Date(y, m - 1, 1).getTime();
}

const cityBars = permits.map(city => {
  const start = monthToTime(city.testStart);
  const end = city.commercialLaunch ? monthToTime(city.commercialLaunch) : axisEnd;
  return {
    city: city.city.replace(/, \w+$/, ''),
    left: ((start - axisStart) / axisSpan) * 100,
    width: ((end - start) / axisSpan) * 100,
    status: city.status,
    months: city.months,
  };
});

const axisYears = [2023, 2024, 2025, 2026];
const yearMarks = axisYears.map(y => ({
  year: y,
  left: ((new Date(y, 0, 1).getTime() - axisStart) / axisSpan) * 100,
}));
---

<section class="section">
  <div class="container">
    <h2 class="section-title">The Delay</h2>
    <p class="section-subtitle">A timeline of DC's autonomous vehicle regulatory failure</p>

    <div class="delay-layout">
      <div class="timeline">
        {events.map((event, i) => (
          <div class={`timeline-node ${i === events.length - 1 ? 'active' : ''}`}>
            <div class="timeline-dot" />
            <div class="timeline-date">{event.date}</div>
            <div class="timeline-event">{event.event}</div>
            <div class="timeline-detail">{event.detail}</div>
            {event.cumulativeDeaths !== null && event.cumulativeDeaths > 0 && (
              <div class="timeline-deaths">
                {event.cumulativeDeaths} road deaths since delay began
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="gantt-panel">
        <div class="gantt-header">Meanwhile, elsewhere</div>
        <div class="gantt-chart">
          <div class="gantt-axis">
            {yearMarks.map(ym => (
              <div class="gantt-year" style={`left: ${ym.left}%`}>{ym.year}</div>
            ))}
          </div>
          {cityBars.map(bar => (
            <div class="gantt-row">
              <div class="gantt-city">{bar.city}</div>
              <div class="gantt-track">
                <div
                  class={`gantt-bar ${bar.status}`}
                  style={`left: ${bar.left}%; width: ${bar.width}%`}
                />
              </div>
              <div class="gantt-label">
                {bar.status === 'waiting' ? `${bar.months}+ mo` : `${bar.months} mo`}
              </div>
            </div>
          ))}
          <div class="gantt-legend">
            <span class="gantt-legend-item"><span class="gantt-dot approved" /> Testing → launched</span>
            <span class="gantt-legend-item"><span class="gantt-dot waiting" /> Testing → still waiting</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
